# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage
/playwright-report/
/test-results/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# preprocessed data (extracted from .gz during build)
/public/data/**
# Allow compressed data files
!/public/data/*.gz
# Allow MOF budget data (small static file)
!/public/data/mof-budget-overview-*.json
# Allow houjin lookup (NTA corporate number subset for entities browser, ~2.4MB)
!/public/data/houjin-lookup.json
# Allow entity labels (generated by generate-entity-labels-csv.py, ~4MB)
!/public/data/entity-labels-csv.json
# Allow project quality scores (generated by score-project-quality.py, ~4MB)
!/public/data/project-quality-scores-2024.json
!/public/data/project-quality-scores-2025.json
# project-quality-recipients-{YEAR}.json: .gz only（28MB→3MB）、ビルド時に自動展開
# 生JSONはGit管理対象外（!/public/data/*.gz で .gz のみ許可済み）
# Allow entity normalization dict (curated mapping, needed to regenerate structured JSON)
!/public/data/entity-normalization.json
# Allow entity labeling dictionaries (exact-match label CSVs, generated by scripts/generate-*.py)
!/public/data/dictionaries/
!/public/data/dictionaries/*.csv

# raw CSV data (939MB) and build artifacts (houjin.db etc.)
/data/

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Python cache
__pycache__/
*.pyc

# --- IGNORE ---
docs/*ignore*
