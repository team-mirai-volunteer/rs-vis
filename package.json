{
  "name": "marumie-rssystem",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "bash scripts/decompress-data.sh",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "generate-project-details": "tsx scripts/generate-project-details.ts",
    "generate-mof-data": "tsx scripts/generate-mof-budget-overview-data.ts",
    "score-quality": "python3 scripts/score-project-quality.py",
    "score-quality-2025": "python3 scripts/score-project-quality.py --year 2025",
    "score-quality-ai": "python3 scripts/score-project-quality-ai.py --year 2024",
    "score-quality-ai-2025": "python3 scripts/score-project-quality-ai.py --year 2025",
    "generate-subcontracts": "tsx scripts/generate-subcontracts.ts 2024",
    "generate-subcontracts-2025": "tsx scripts/generate-subcontracts.ts 2025",
    "generate-sankey-svg": "tsx scripts/generate-sankey-svg-data.ts 2024",
    "generate-sankey-svg-2025": "tsx scripts/generate-sankey-svg-data.ts 2025",
    "generate-recipient-index": "tsx scripts/generate-recipient-index.ts 2024",
    "generate-recipient-index-2025": "tsx scripts/generate-recipient-index.ts 2025",
    "compress-data": "gzip -9 -k -f public/data/rs2024-project-details.json && gzip -9 -k -f public/data/rs2025-project-details.json && gzip -9 -k -f public/data/project-quality-recipients-2024.json && gzip -9 -k -f public/data/project-quality-recipients-2025.json && gzip -9 -k -f public/data/sankey-svg-2024-graph.json && gzip -9 -k -f public/data/sankey-svg-2025-graph.json && gzip -9 -k -f public/data/subcontracts-2024.json && gzip -9 -k -f public/data/subcontracts-2025.json && gzip -9 -k -f public/data/recipient-index-2024.json && gzip -9 -k -f public/data/recipient-index-2025.json && gzip -9 -k -f public/data/project-quality-scores-2024.json && gzip -9 -k -f public/data/project-quality-scores-2025.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dagrejs/dagre": "^2.0.4",
    "@nivo/sankey": "^0.99.0",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@xyflow/react": "^12.10.1",
    "d3-hierarchy": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "dagre": "^0.8.5",
    "next": "15.1.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.183.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.4",
    "iconv-lite": "^0.6.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
