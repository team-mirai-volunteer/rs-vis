{
  "name": "marumie-rssystem",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "bash scripts/decompress-data.sh",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "normalize": "python3 scripts/normalize_csv.py",
    "normalize-2025": "python3 scripts/normalize_csv.py --year 2025",
    "generate-structured": "tsx scripts/generate-structured-json.ts",
    "generate-project-details": "tsx scripts/generate-project-details.ts",
    "generate-mof-data": "tsx scripts/generate-mof-budget-overview-data.ts",
    "score-quality": "python3 scripts/score-project-quality.py",
    "score-quality-2025": "python3 scripts/score-project-quality.py --year 2025",
    "generate-subcontracts": "tsx scripts/generate-subcontracts.ts 2024",
    "generate-subcontracts-2025": "tsx scripts/generate-subcontracts.ts 2025",
    "compress-data": "gzip -9 -k public/data/rs2024-structured.json && gzip -9 -k public/data/rs2024-project-details.json && gzip -9 -k -f public/data/project-quality-recipients-2024.json && gzip -9 -k -f public/data/project-quality-recipients-2025.json && gzip -9 -k -f public/data/sankey2-graph.json && gzip -9 -k -f public/data/sankey2-layout.json && gzip -9 -k -f public/data/sankey-svg-2024-graph.json && gzip -9 -k -f public/data/sankey-svg-2025-graph.json && gzip -9 -k -f public/data/subcontracts-2024.json && gzip -9 -k -f public/data/subcontracts-2025.json",
    "generate-entity-dict": "tsx scripts/generate-entity-dict.ts",
    "validate-tags": "tsx scripts/validate-tags.ts",
    "build-houjin-db": "python3 scripts/build-houjin-sqlite.py",
    "build-houjin-lookup": "python3 scripts/build-houjin-lookup.py",
    "generate-entity-labels": "python3 scripts/generate-entity-labels.py",
    "generate-entity-labels-csv": "python3 scripts/generate-entity-labels-csv.py",
    "generate-sankey2": "tsx scripts/generate-sankey2-data.ts",
    "compute-sankey2-layout": "tsx scripts/compute-sankey2-layout.ts",
    "generate-sankey-svg": "tsx scripts/generate-sankey-svg-data.ts 2024",
    "generate-sankey-svg-2025": "tsx scripts/generate-sankey-svg-data.ts 2025",
    "setup": "npm install && npm run normalize && npm run generate-structured && npm run generate-project-details"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dagrejs/dagre": "^2.0.4",
    "@nivo/sankey": "^0.99.0",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@xyflow/react": "^12.10.1",
    "d3-hierarchy": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "dagre": "^0.8.5",
    "next": "15.1.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.183.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.4",
    "iconv-lite": "^0.6.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
